{
  "name": "accountancy-app",
  "version": "26.6.2102",
  "description": "Accountancy App",
  "main": "main.js",
  "scripts": {
    "test": "jest",
    "set-version": "node set-version.js",
    "fix-base": "node scripts/fix-base.js",
    "start": "electron .",
    "electron:watch": "wait-on http://localhost:4200 && nodemon --watch electron --ext ts --exec \"electron .\"",
    "dev": "concurrently \"npm run electron:watch\" \"cd ../accountancy-app-ng16 && npm start\"",
    "clean:accountancy-app": "if exist accountancy-app rmdir /s /q accountancy-app && mkdir accountancy-app",
    "clean": "rimraf dist && npm run clean:accountancy-app",
    "copy:angular-build": "npx copyfiles -u 4 ../accountancy-app-ng16/dist/accountancy-app/**/* accountancy-app",
    "copy": "npm run clean && npm run copy:angular-build && npm run fix-base",
    "publish": "npm run set-version && npm run clean && npm run copy && npx electron-builder --publish always",
    "build": "npm run set-version && npm run copy && electron-builder"
  },
  "repository": "https://github.com/netplusmrt/accountancy-app-electron",
  "publish": {
    "provider": "github",
    "releaseType": "release"
  },
  "build": {
    "appId": "com.netplusmrt.accountancyapp",
    "productName": "AccountancyApp",
    "icon": "assets/icon.ico",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "artifactName": "AccountancyApp-Setup-${version}.exe"
    },
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "releaseType": "release"
    }
  },
  "author": "AccountancyApp",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^10.0.3",
    "electron": "^34.1.1",
    "electron-builder": "^25.1.8",
    "electron-debug": "^4.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "axios": "^1.18.0",
    "electron-log": "^5.3.0",
    "electron-updater": "^6.3.9",
    "keytar": "^7.9.0",
    "semver": "^7.8.5"
  }
}